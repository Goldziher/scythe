{%- else %}
	user, err := queries.CreateUser(ctx, pool, "Alice", &email, queries.UserStatusActive)
{%- endif %}
	if err != nil {
		fail(name, err)
		return
	}
	if !assertf(name, user.Name == "Alice", "expected name Alice, got %s", user.Name) {
		return
