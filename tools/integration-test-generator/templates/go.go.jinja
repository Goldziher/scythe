{% if driver == "pgx" %}
func runMigration(ctx context.Context, pool *pgxpool.Pool) error {
	_, thisFile, _, _ := runtime.Caller(0)
{%- if engine == "redshift" %}
	schemaPath := filepath.Join(filepath.Dir(thisFile), "..", "sql", "redshift", "schema_pg_compat.sql")
{%- else %}
	schemaPath := filepath.Join(filepath.Dir(thisFile), "..", "sql", "pg", "schema.sql")
{%- endif %}

	schema, err := os.ReadFile(schemaPath)
	if err != nil {
		return fmt.Errorf("reading schema file at %s: %w", schemaPath, err)
	}

	dropSQL := `
		DROP TABLE IF EXISTS user_tags CASCADE;
		DROP TABLE IF EXISTS tags CASCADE;
		DROP TABLE IF EXISTS orders CASCADE;
		DROP TABLE IF EXISTS users CASCADE;
{%- if engine != "redshift" %}
		DROP TYPE IF EXISTS user_status CASCADE;
{%- endif %}
	`
	if _, err := pool.Exec(ctx, dropSQL); err != nil {
		return fmt.Errorf("dropping tables: %w", err)
	}

	if _, err := pool.Exec(ctx, string(schema)); err != nil {
		return fmt.Errorf("creating schema: %w", err)
	}

	return nil
}

