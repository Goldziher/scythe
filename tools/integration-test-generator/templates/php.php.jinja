function test_create_user({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo): {% if engine == "mariadb" %}string{% else %}int{% endif %}
{
    {%- if engine == "postgresql" %}
    $user = Queries::createUser($pdo, "Alice", "alice@example.com", UserStatus::ACTIVE);
    {%- elif engine == "redshift" %}
    $user = Queries::createUser($pdo, "Alice", "alice@example.com", "active");
    {%- elif engine == "mysql" %}
    Queries::createUser($pdo, "Alice", "alice@example.com", UsersStatus::ACTIVE);
    $user = Queries::getLastInsertUser($pdo);
    {%- elif engine == "mariadb" %}
    $user = Queries::createUser($pdo, "Alice", "alice@example.com", UsersStatus::ACTIVE);
    {%- elif engine == "mssql" %}
    $user = Queries::createUser($pdo, 1, "Alice", "alice@example.com", true);
    {%- elif engine == "snowflake" %}
    Queries::createUser($pdo, "Alice", "alice@example.com");
    $user = Queries::getUserById($pdo, 1);
    {%- else %}
    $user = Queries::createUser($pdo, "Alice", "alice@example.com");
    {%- endif %}
    assert_not_null($user, "CreateUser returned null");
    assert_equal("Alice", $user->name, "CreateUser name");
    assert_equal("alice@example.com", $user->email, "CreateUser email");
    echo "PASS: CreateUser\n";
    return $user->id;
}

function test_get_user_by_id({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo, {% if engine == "mariadb" %}string{% else %}int{% endif %} $user_id): void
{
    $user = Queries::getUserById($pdo, $user_id);
    assert_not_null($user, "GetUserById returned null for id={$user_id}");
    assert_equal("Alice", $user->name, "GetUserById name");
    assert_equal($user_id, $user->id, "GetUserById id");
    echo "PASS: GetUserById\n";
}

function test_list_active_users({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo): void
{
    {%- if engine == "postgresql" %}
    $users = iterator_to_array(Queries::listActiveUsers($pdo, UserStatus::ACTIVE));
    {%- elif engine == "redshift" %}
    $users = iterator_to_array(Queries::listActiveUsers($pdo, "active"));
    {%- elif engine == "mysql" or engine == "mariadb" %}
    $users = iterator_to_array(Queries::listActiveUsers($pdo, UsersStatus::ACTIVE));
    {%- else %}
    $users = iterator_to_array(Queries::listActiveUsers($pdo));
    {%- endif %}
    assert_true(count($users) >= 1, "Expected at least 1 active user, got " . count($users));
    $names = array_map(fn($u) => $u->name, $users);
    assert_true(in_array("Alice", $names, true), "Expected 'Alice' in active users");
    echo "PASS: ListActiveUsers\n";
}

function test_create_order({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo, {% if engine == "mariadb" %}string{% else %}int{% endif %} $user_id): int
{
    {%- if engine == "mysql" %}
    Queries::createOrder($pdo, $user_id, "49.99", "Test order");
    $order = Queries::getLastInsertOrder($pdo);
    {%- elif engine == "mssql" %}
    $order = Queries::createOrder($pdo, 1, $user_id, "49.99", "Test order");
    {%- elif engine == "snowflake" %}
    Queries::createOrder($pdo, $user_id, "49.99", "Test order");
    $orders = iterator_to_array(Queries::getOrdersByUser($pdo, $user_id));
    $order = !empty($orders) ? $orders[0] : null;
    {%- else %}
    $order = Queries::createOrder($pdo, $user_id, "49.99", "Test order");
    {%- endif %}
    assert_not_null($order, "CreateOrder returned null");
    assert_equal($user_id, $order->user_id, "CreateOrder user_id");
    assert_equal("Test order", $order->notes, "CreateOrder notes");
    echo "PASS: CreateOrder\n";
    return $order->id;
}

function test_get_orders_by_user({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo, {% if engine == "mariadb" %}string{% else %}int{% endif %} $user_id): void
{
    $orders = iterator_to_array(Queries::getOrdersByUser($pdo, $user_id));
    assert_true(count($orders) >= 1, "Expected at least 1 order, got " . count($orders));
    assert_equal("Test order", $orders[0]->notes, "GetOrdersByUser notes");
    echo "PASS: GetOrdersByUser\n";
}

function test_delete_user({% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" %}PDO {% endif %}$pdo, {% if engine == "mariadb" %}string{% else %}int{% endif %} $user_id): void
{
    // Delete orders first due to FK constraint
    Queries::deleteOrdersByUser($pdo, $user_id);
    Queries::deleteUser($pdo, $user_id);
    $user = Queries::getUserById($pdo, $user_id);
    assert_true($user === null || $user === false, "Expected user to be deleted, but it still exists");
    echo "PASS: DeleteUser\n";
}

try {
    $database_url = get_database_url();
    {% if driver == "pdo" or driver == "pdo-mysql" or driver == "pdo-sqlite" or driver == "pdo-mssql" -%}
    $pdo = create_pdo($database_url);
    {%- elif driver == "amphp" -%}
    $pdo = create_connection($database_url);
    {%- endif %}

    setup_schema($pdo);

    $user_id = test_create_user($pdo);
    test_get_user_by_id($pdo, $user_id);
    test_list_active_users($pdo);
    $order_id = test_create_order($pdo, $user_id);
    test_get_orders_by_user($pdo, $user_id);
    test_delete_user($pdo, $user_id);

    echo "\nALL TESTS PASSED\n";
    exit(0);
} catch (Throwable $e) {
    fwrite(STDERR, "FAIL: " . $e->getMessage() . "\n");
    fwrite(STDERR, $e->getTraceAsString() . "\n");
    exit(1);
}
