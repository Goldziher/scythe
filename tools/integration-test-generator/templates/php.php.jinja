function get_database_url(): string
{
    $url = getenv('{{ connection_env }}');
    if ($url === false || $url === '') {
        fwrite(STDERR, "ERROR: {{ connection_env }} environment variable is not set\n");
        exit(1);
    }
    return $url;
}

{% if engine == "postgresql" -%}
function parse_database_url(string $url): array
{
    $parts = parse_url($url);
    if ($parts === false) {
        fwrite(STDERR, "ERROR: Invalid {{ connection_env }} format\n");
        exit(1);
    }
    return [
        'host' => $parts['host'] ?? 'localhost',
        'port' => $parts['port'] ?? 5432,
        'dbname' => ltrim($parts['path'] ?? '/scythe_test', '/'),
        'user' => $parts['user'] ?? 'scythe',
        'password' => $parts['pass'] ?? 'scythe',
    ];
}

{%- if driver == "pdo" %}

function create_pdo(string $url): PDO
{
    $params = parse_database_url($url);
    $dsn = sprintf(
        'pgsql:host=%s;port=%d;dbname=%s',
        $params['host'],
        $params['port'],
        $params['dbname']
    );
    $pdo = new PDO($dsn, $params['user'], $params['password'], [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
    ]);
    return $pdo;
}
{%- elif driver == "amphp" %}

function create_connection(string $url): \Amp\Postgres\PostgresConnection
{
    $params = parse_database_url($url);
    $config = new \Amp\Postgres\PostgresConfig(
        $params['host'],
        $params['port'],
        $params['user'],
        $params['password'],
        $params['dbname'],
    );
    return \Amp\Postgres\connect($config);
}
{%- endif %}
{%- elif engine == "mysql" -%}
