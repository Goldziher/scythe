# Clean slate: drop tables and sequences, ignoring errors if they do not exist.
for table <- ["user_tags", "tags", "orders", "users"] do
  Jamdb.Oracle.query(conn, "DROP TABLE #{table} CASCADE CONSTRAINTS", [])
end

