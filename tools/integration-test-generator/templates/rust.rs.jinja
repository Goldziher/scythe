#[allow(dead_code, unused_imports, clippy::all)]
mod generated;

use generated::{
    CreateOrderRow, CreateUserRow, GetOrdersByUserRow, GetUserByIdRow, ListActiveUsersRow,
{%- if engine == "postgresql" %}
    UserStatus,
{%- endif %}
};
{%- if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" %}
use rust_decimal::Decimal;
{%- if driver == "sqlx" %}
use sqlx::postgres::PgPoolOptions;
{%- elif driver == "sqlx-mysql" %}
use sqlx::mysql::MySqlPoolOptions;
{%- elif driver == "sqlx-sqlite" %}
use sqlx::sqlite::SqlitePoolOptions;
{%- endif %}
{%- elif driver == "tokio-postgres" %}
use rust_decimal::Decimal;
use tokio_postgres::NoTls;
{%- endif %}
use std::str::FromStr;

macro_rules! assert_test {
    ($cond:expr, $name:expr) => {
        if !($cond) {
            eprintln!("FAIL: {}: assertion failed: {}", $name, stringify!($cond));
            std::process::exit(1);
        }
    };
}

macro_rules! pass {
    ($name:expr) => {
        println!("PASS: {}", $name);
    };
}

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let database_url =
        std::env::var("{{ connection_env }}").expect("{{ connection_env }} environment variable required");

{% if driver == "sqlx" -%}
    let pool = PgPoolOptions::new()
        .max_connections(5)
        .connect(&database_url)
        .await?;

    // Clean slate: drop tables in dependency order, then recreate
    sqlx::query("DROP TABLE IF EXISTS user_tags CASCADE")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS tags CASCADE")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS orders CASCADE")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS users CASCADE")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TYPE IF EXISTS user_status CASCADE")
        .execute(&pool)
        .await?;

    let schema_sql = std::fs::read_to_string("{{ schema_dir }}/schema.sql")?;
    sqlx::query(&schema_sql).execute(&pool).await?;
{%- elif driver == "sqlx-mysql" -%}
    let pool = MySqlPoolOptions::new()
        .max_connections(5)
        .connect(&database_url)
        .await?;

    // Clean slate: drop tables in dependency order, then recreate
    sqlx::query("DROP TABLE IF EXISTS user_tags")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS tags")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS orders")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS users")
        .execute(&pool)
        .await?;

    let schema_sql = std::fs::read_to_string("{{ schema_dir }}/schema.sql")?;
    for stmt in schema_sql.split(';') {
        let stmt = stmt.trim();
        if !stmt.is_empty() {
            sqlx::query(stmt).execute(&pool).await?;
        }
    }
{%- elif driver == "sqlx-sqlite" -%}
    let pool = SqlitePoolOptions::new()
        .max_connections(5)
        .connect(&database_url)
        .await?;

    // Clean slate: drop tables in dependency order, then recreate
    sqlx::query("DROP TABLE IF EXISTS user_tags")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS tags")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS orders")
        .execute(&pool)
        .await?;
    sqlx::query("DROP TABLE IF EXISTS users")
        .execute(&pool)
        .await?;

    let schema_sql = std::fs::read_to_string("{{ schema_dir }}/schema.sql")?;
    sqlx::query(&schema_sql).execute(&pool).await?;
{%- elif driver == "tokio-postgres" -%}
    let (client, connection) = tokio_postgres::connect(&database_url, NoTls).await?;

    // Spawn connection handler
    tokio::spawn(async move {
        if let Err(err) = connection.await {
            eprintln!("connection error: {}", err);
        }
    });

    // Clean slate: drop tables in dependency order, then recreate
    client
        .execute("DROP TABLE IF EXISTS user_tags CASCADE", &[])
        .await?;
    client
        .execute("DROP TABLE IF EXISTS tags CASCADE", &[])
        .await?;
    client
        .execute("DROP TABLE IF EXISTS orders CASCADE", &[])
        .await?;
    client
        .execute("DROP TABLE IF EXISTS users CASCADE", &[])
        .await?;
    client
        .execute("DROP TYPE IF EXISTS user_status CASCADE", &[])
        .await?;

    let schema_sql = std::fs::read_to_string("{{ schema_dir }}/schema.sql")?;
    client.batch_execute(&schema_sql).await?;
{%- endif %}

    // Test: CreateUser
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    let user: CreateUserRow = sqlx::query_as(
        "INSERT INTO users (name, email{% if engine == "postgresql" %}, status{% endif %}) VALUES ($1, $2{% if engine == "postgresql" %}, $3{% endif %}) RETURNING id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at",
    )
    .bind("Alice")
    .bind("alice@example.com")
{%- if engine == "postgresql" %}
    .bind(UserStatus::Active)
{%- endif %}
    .fetch_one(&pool)
    .await?;
{%- elif driver == "tokio-postgres" %}
    let row = client
        .query_one(
            "INSERT INTO users (name, email{% if engine == "postgresql" %}, status{% endif %}) VALUES ($1, $2{% if engine == "postgresql" %}, $3{% endif %}) RETURNING id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at",
            &[&"Alice", &"alice@example.com"{% if engine == "postgresql" %}, &UserStatus::Active{% endif %}],
        )
        .await?;
    let user = CreateUserRow::from(row);
{%- endif %}
    assert_test!(user.name == "Alice", "CreateUser");
    assert_test!(
        user.email.as_deref() == Some("alice@example.com"),
        "CreateUser"
    );
{%- if engine == "postgresql" %}
    assert_test!(user.status == UserStatus::Active, "CreateUser");
{%- endif %}
    let user_id = user.id;
    pass!("CreateUser");

    // Test: GetUserById
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    let fetched: GetUserByIdRow =
        sqlx::query_as("SELECT id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at FROM users WHERE id = $1")
            .bind(user_id)
            .fetch_one(&pool)
            .await?;
{%- elif driver == "tokio-postgres" %}
    let row = client
        .query_one(
            "SELECT id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at FROM users WHERE id = $1",
            &[&user_id],
        )
        .await?;
    let fetched = GetUserByIdRow::from(row);
{%- endif %}
    assert_test!(fetched.id == user_id, "GetUserById");
    assert_test!(fetched.name == "Alice", "GetUserById");
    assert_test!(
        fetched.email.as_deref() == Some("alice@example.com"),
        "GetUserById"
    );
{%- if engine == "postgresql" %}
    assert_test!(fetched.status == UserStatus::Active, "GetUserById");
{%- endif %}
    pass!("GetUserById");

    // Test: ListActiveUsers
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    let active_users: Vec<ListActiveUsersRow> =
        sqlx::query_as("SELECT id, name, email FROM users WHERE status = $1")
{%- if engine == "postgresql" %}
            .bind(UserStatus::Active)
{%- endif %}
            .fetch_all(&pool)
            .await?;
{%- elif driver == "tokio-postgres" %}
    let rows = client
        .query(
            "SELECT id, name, email FROM users WHERE status = $1",
            &[{% if engine == "postgresql" %}&UserStatus::Active{% endif %}],
        )
        .await?;
    let active_users: Vec<ListActiveUsersRow> = rows.into_iter().map(ListActiveUsersRow::from).collect();
{%- endif %}
    assert_test!(!active_users.is_empty(), "ListActiveUsers");
    assert_test!(active_users[0].name == "Alice", "ListActiveUsers");
    pass!("ListActiveUsers");

    // Test: CreateOrder
    let total = Decimal::from_str("99.95").unwrap();
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    let order: CreateOrderRow = sqlx::query_as(
        "INSERT INTO orders (user_id, total, notes) VALUES ($1, $2, $3) RETURNING id, user_id, total, notes, created_at",
    )
    .bind(user_id)
    .bind(&total)
    .bind("first order")
    .fetch_one(&pool)
    .await?;
{%- elif driver == "tokio-postgres" %}
    let row = client
        .query_one(
            "INSERT INTO orders (user_id, total, notes) VALUES ($1, $2, $3) RETURNING id, user_id, total, notes, created_at",
            &[&user_id, &total, &"first order"],
        )
        .await?;
    let order = CreateOrderRow::from(row);
{%- endif %}
    assert_test!(order.user_id == user_id, "CreateOrder");
    assert_test!(order.total == total, "CreateOrder");
    assert_test!(
        order.notes.as_deref() == Some("first order"),
        "CreateOrder"
    );
    pass!("CreateOrder");

    // Test: GetOrdersByUser
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    let orders: Vec<GetOrdersByUserRow> = sqlx::query_as(
        "SELECT id, total, notes, created_at FROM orders WHERE user_id = $1 ORDER BY created_at DESC",
    )
    .bind(user_id)
    .fetch_all(&pool)
    .await?;
{%- elif driver == "tokio-postgres" %}
    let rows = client
        .query(
            "SELECT id, total, notes, created_at FROM orders WHERE user_id = $1 ORDER BY created_at DESC",
            &[&user_id],
        )
        .await?;
    let orders: Vec<GetOrdersByUserRow> = rows.into_iter().map(GetOrdersByUserRow::from).collect();
{%- endif %}
    assert_test!(orders.len() == 1, "GetOrdersByUser");
    assert_test!(orders[0].total == total, "GetOrdersByUser");
    pass!("GetOrdersByUser");

    // Test: DeleteUser (delete orders first due to FK)
{% if driver == "sqlx" or driver == "sqlx-mysql" or driver == "sqlx-sqlite" -%}
    sqlx::query("DELETE FROM orders WHERE user_id = $1")
        .bind(user_id)
        .execute(&pool)
        .await?;
    sqlx::query("DELETE FROM users WHERE id = $1")
        .bind(user_id)
        .execute(&pool)
        .await?;
    // Verify user is gone
    let deleted: Option<GetUserByIdRow> =
        sqlx::query_as("SELECT id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at FROM users WHERE id = $1")
            .bind(user_id)
            .fetch_optional(&pool)
            .await?;
{%- elif driver == "tokio-postgres" %}
    client
        .execute("DELETE FROM orders WHERE user_id = $1", &[&user_id])
        .await?;
    client
        .execute("DELETE FROM users WHERE id = $1", &[&user_id])
        .await?;
    // Verify user is gone
    let row = client
        .query_opt(
            "SELECT id, name, email{% if engine == "postgresql" %}, status{% endif %}, created_at FROM users WHERE id = $1",
            &[&user_id],
        )
        .await?;
    let deleted: Option<GetUserByIdRow> = row.map(GetUserByIdRow::from);
{%- endif %}
    assert_test!(deleted.is_none(), "DeleteUser");
    pass!("DeleteUser");

    println!("ALL TESTS PASSED");
    Ok(())
}
