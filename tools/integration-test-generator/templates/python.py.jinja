async def setup_schema(conn: psycopg.AsyncConnection) -> None:
    """Drop all tables and recreate schema from SQL file."""
{%- if engine == "postgresql" or engine == "redshift" %}
    await conn.execute("DROP TABLE IF EXISTS user_tags CASCADE")
    await conn.execute("DROP TABLE IF EXISTS tags CASCADE")
    await conn.execute("DROP TABLE IF EXISTS orders CASCADE")
    await conn.execute("DROP TABLE IF EXISTS users CASCADE")
{%- if engine == "postgresql" and engine != "redshift" %}
    await conn.execute("DROP TYPE IF EXISTS user_status CASCADE")
{%- endif %}
{%- endif %}
    schema_sql = SCHEMA_PATH.read_text()
    await conn.execute(schema_sql)
    await conn.commit()
