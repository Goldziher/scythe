    user_id = max_id_row[0] if max_id_row and max_id_row[0] else 1
    user = get_user_by_id(conn, id=user_id)
{%- elif engine == "redshift" %}
    user = await create_user(
        conn, name="Alice", email="alice@example.com", status="active"
    )
{%- else %}
    user = await create_user(
        conn, name="Alice", email="alice@example.com"
        {%- if engine == "postgresql" %}, status=UserStatus.ACTIVE
        {%- elif engine == "mariadb" %}, status=UsersStatus.ACTIVE{%- endif %}
    )
