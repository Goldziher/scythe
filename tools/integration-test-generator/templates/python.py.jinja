def run_tests() -> None:
{%- endif %}
    """Run all integration tests."""
{%- if driver != "snowflake" %}
    database_url = get_database_url()
{%- endif %}
{%- if driver == "psycopg3" %}
    async with await psycopg.AsyncConnection.connect(database_url) as conn:
        await setup_schema(conn)
{% if options.row_type == "pydantic" %}
        await test_row_types_are_pydantic_models()
{%- endif %}
        user_id = await test_create_user(conn)
        await test_get_user_by_id(conn, user_id)
        await test_list_active_users(conn)
        order_id = await test_create_order(conn, user_id)
        await test_get_orders_by_user(conn, user_id)
        await test_delete_user(conn, user_id)
{%- elif driver == "asyncpg" %}
    conn = await asyncpg.connect(database_url)
    try:
        await setup_schema(conn)

        user_id = await test_create_user(conn)
        await test_get_user_by_id(conn, user_id)
        await test_list_active_users(conn)
        order_id = await test_create_order(conn, user_id)
        await test_get_orders_by_user(conn, user_id)
        await test_delete_user(conn, user_id)
    finally:
        await conn.close()
{%- elif driver == "aiomysql" %}
    from urllib.parse import urlparse
    parsed = urlparse(database_url)
    conn = await aiomysql.connect(
        host=parsed.hostname or "127.0.0.1",
        port=parsed.port or 3306,
        user=parsed.username or "root",
        password=parsed.password or "",
        db=parsed.path.lstrip("/") or "scythe_test",
    )
    try:
        await setup_schema(conn)

        user_id = await test_create_user(conn)
        await test_get_user_by_id(conn, user_id)
        await test_list_active_users(conn)
        order_id = await test_create_order(conn, user_id)
        await test_get_orders_by_user(conn, user_id)
        await test_delete_user(conn, user_id)
    finally:
        conn.close()
{%- elif driver == "aiosqlite" %}
    conn = await aiosqlite.connect(database_url)
    try:
        await setup_schema(conn)

        user_id = await test_create_user(conn)
        await test_get_user_by_id(conn, user_id)
        await test_list_active_users(conn)
        order_id = await test_create_order(conn, user_id)
        await test_get_orders_by_user(conn, user_id)
        await test_delete_user(conn, user_id)
    finally:
        await conn.close()
{%- elif driver == "oracledb" %}
    oracledb.defaults.fetch_lobs = False
    from urllib.parse import urlparse
    parsed = urlparse(database_url)
    dsn = f"{parsed.hostname}:{parsed.port}{parsed.path}"
    conn = await oracledb.connect_async(
        user=parsed.username,
        password=parsed.password,
        dsn=dsn,
    )
    try:
        await setup_schema(conn)

        user_id = await test_create_user(conn)
        await test_get_user_by_id(conn, user_id)
        await test_list_active_users(conn)
        order_id = await test_create_order(conn, user_id)
        await test_get_orders_by_user(conn, user_id)
        await test_delete_user(conn, user_id)
    finally:
        await conn.close()
{%- elif driver == "pyodbc" %}
    from urllib.parse import urlparse
    parsed = urlparse(database_url)
    server = f"{parsed.hostname},{parsed.port}" if parsed.port else parsed.hostname
    database = parsed.path.lstrip("/") or "master"
    conn_str = "DRIVER={ODBC Driver 18 for SQL Server};SERVER=%s;DATABASE=%s;UID=%s;PWD=%s;TrustServerCertificate=yes" % (server, database, parsed.username, parsed.password)
    conn = pyodbc.connect(conn_str)
    try:
        setup_schema(conn)
{% if options.row_type == "pydantic" %}
        test_row_types_are_pydantic_models()
{%- endif %}
        user_id = test_create_user(conn)
        test_get_user_by_id(conn, user_id)
        test_list_active_users(conn)
        order_id = test_create_order(conn, user_id)
        test_get_orders_by_user(conn, user_id)
        test_delete_user(conn, user_id)
    finally:
        conn.close()
{%- elif driver == "snowflake" %}
    use_fakesnow = os.environ.get("SNOWFLAKE_USE_FAKESNOW", "0") == "1"
    if use_fakesnow:
        if not fakesnow:
            print("ERROR: fakesnow not installed but SNOWFLAKE_USE_FAKESNOW=1", file=sys.stderr)
            sys.exit(1)
        with fakesnow.patch():
            conn = snowflake.connector.connect(database="testdb", schema="public")
            try:
                setup_schema(conn)
{% if options.row_type == "pydantic" %}
