def get_database_url() -> str:
    """Read {{ connection_env }} from environment."""
    url = os.environ.get("{{ connection_env }}")
    if not url:
        print("ERROR: {{ connection_env }} environment variable is not set", file=sys.stderr)
        sys.exit(1)
    return url


