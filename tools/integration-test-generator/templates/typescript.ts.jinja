{%- elif driver == "mssql" -%}
import sql from "mssql";
{%- elif driver == "snowflake" -%}
import snowflake from "snowflake-sdk";
{%- endif %}
{%- if options.row_type == "zod" %}
import { z } from "zod";
{%- endif %}
import {
	createUser,
	getUserById,
	listActiveUsers,
	createOrder,
	getOrdersByUser,
	deleteOrdersByUser,
	deleteUser,
{%- if engine == "postgresql" and engine != "redshift" %}
	UserStatusValues,
{%- elif engine == "mysql" %}
	UsersStatus,
	getLastInsertUser,
	getLastInsertOrder,
{%- elif engine == "mariadb" %}
	UsersStatus,
{%- endif %}
{%- if options.row_type == "zod" %}
	CreateUserRowSchema,
	GetUserByIdRowSchema,
	ListActiveUsersRowSchema,
	CreateOrderRowSchema,
	GetOrdersByUserRowSchema,
{%- endif %}
} from "./generated/queries.js";

const DATABASE_URL =
	process.env["{{ connection_env }}"] ??
	"{% if engine == "postgresql" %}postgres://scythe:scythe@localhost:5432/scythe_test{% elif engine == "mysql" or engine == "mariadb" %}mysql://root@localhost:3306/scythe_test{% elif engine == "sqlite" %}test.db{% elif engine == "oracle" %}oracle://scythe:scythe@localhost:1521/XEPDB1{% elif engine == "mssql" %}sqlserver://sa:Scythe_Test1@localhost:1433?database=scythe_test{% elif engine == "snowflake" %}snowflake://account:password@host/database/schema{% endif %}";
{% if driver == "pg" %}
const pool = new pg.Pool({ connectionString: DATABASE_URL });
{%- elif driver == "postgres" %}
const sql = postgres(DATABASE_URL);
{%- endif %}

let exitCode = 0;

function assert(condition: boolean, testName: string, detail: string): void {
	if (!condition) {
		console.error(`FAIL: ${testName}: ${detail}`);
		exitCode = 1;
	}
}

async function main(): Promise<void> {
{%- if driver == "pg" %}
	const client = await pool.connect();
	try {
		// Clean slate
{%- if engine == "postgresql" %}
		await client.query("DROP TABLE IF EXISTS user_tags CASCADE");
		await client.query("DROP TABLE IF EXISTS tags CASCADE");
		await client.query("DROP TABLE IF EXISTS orders CASCADE");
		await client.query("DROP TABLE IF EXISTS users CASCADE");
		await client.query("DROP TYPE IF EXISTS user_status CASCADE");

		await client.query(
			"CREATE TYPE user_status AS ENUM ('active', 'inactive', 'banned')",
