{%- if driver == "pg" -%}
import pg from "pg";
{%- elif driver == "postgres" -%}
import postgres from "postgres";
{%- elif driver == "mysql2" -%}
import mysql from "mysql2/promise";
{%- elif driver == "better-sqlite3" -%}
import Database from "better-sqlite3";
{%- elif driver == "oracledb" -%}
